+  private linkedSpaces: Map<string, string> = new Map();
+
+  constructor(
+    private flowEngine: FlowEngine,
+    private spaceEngine: SpaceEngine
+  ) {}
+
+  observeIntegration(): Observable<IntegratedState> {
+    return combineLatest({
+      flow: this.flowEngine.observeFlow(),
+      space: this.spaceEngine.observeSpace(),
+      flowResonance: this.flowEngine.observeResonance(),
+      spaceResonance: this.spaceEngine.observeResonance()
+    }).pipe(
+      debounceTime(100),
+      filter(({ flow, space }) => !!flow && !!space),
+      map(({ flow, space, flowResonance, spaceResonance }) => ({
+        flow,
+        space,
+        resonance: this.combineResonance(flowResonance, spaceResonance),
+        field: this.combineFields(flow.field, space.field)
+      }))
+    );
+  }
+
+  async createFlowSpace(type: FlowType, spaceType: SpaceType): Promise<string> {
+    const flowId = await this.flowEngine.createFlow(type);
+    const spaceId = await this.spaceEngine.createSpace(spaceType);
+    this.linkedSpaces.set(flowId, spaceId);
+    return flowId;
+  }
+
+  async moveFlow(flowId: string, targetSpaceId: string): Promise<void> {
+    const currentSpaceId = this.linkedSpaces.get(flowId);
+    if (currentSpaceId) {
+      await this.spaceEngine.adapt(currentSpaceId);
+    }
+    this.linkedSpaces.set(flowId, targetSpaceId);
+    await this.flowEngine.transition(flowId);
+  }
+
+  async dissolveFlow(flowId: string): Promise<void> {
+    const spaceId = this.linkedSpaces.get(flowId);
+    if (spaceId) {
+      await this.spaceEngine.cleanup(spaceId);
+      this.linkedSpaces.delete(flowId);
+    }
+    await this.flowEngine.end(flowId);
+  }
+
+  private combineResonance(flowRes: Resonance, spaceRes: Resonance): Resonance {
+    return {
+      frequency: (flowRes.frequency + spaceRes.frequency) / 2,
+      amplitude: Math.max(flowRes.amplitude, spaceRes.amplitude),
+      phase: (flowRes.phase + spaceRes.phase) / 2
+    };
+  }
+
+  private combineFields(flowField: Field, spaceField: Field): Field {
+    const center = {
+      x: (flowField.center.x + spaceField.center.x) / 2,
+      y: (flowField.center.y + spaceField.center.y) / 2,
+      z: (flowField.center.z + spaceField.center.z) / 2
+    };
